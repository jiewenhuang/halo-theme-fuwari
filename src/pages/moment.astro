---
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout title="${title + ' - ' + site.title}">
  <Fragment slot="head">
    <title th:text="${title + ' - ' + site.title}"></title>
  </Fragment>

  <article class="card-base relative z-10 mb-4 w-full px-6 pb-8 pt-7 md:px-9" th:with="content=${moment.spec.content}">
    <div class="mb-5 flex items-start gap-3">
      <img
        th:if="${moment.owner != null and not #strings.isEmpty(moment.owner.avatar)}"
        th:src="${moment.owner.avatar}"
        th:alt="${moment.owner.displayName}"
        class="h-12 w-12 rounded-full object-cover"
      />
      <div
        th:unless="${moment.owner != null and not #strings.isEmpty(moment.owner.avatar)}"
        class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-(--btn-regular-bg) text-(--primary)"
      >
        <span class="icon-[material-symbols--account-circle] text-3xl"></span>
      </div>
      <div class="min-w-0 flex-1">
        <h1
          class="text-2xl font-bold text-90 md:text-3xl"
          th:text="${moment.owner != null ? moment.owner.displayName : #messages.msg('page.moments.title')}"
        >Moment</h1>
        <time
          class="text-sm text-50"
          th:datetime="${moment.spec.releaseTime}"
          th:text="${moment.spec.releaseTime != null ? #dates.format(moment.spec.releaseTime, 'yyyy-MM-dd HH:mm') : ''}"
        >2026-04-29 22:00</time>
      </div>
      <a th:href="@{/moments}" class="btn-regular h-9 rounded-lg px-3 text-sm font-bold active:scale-95">
        <span class="icon-[material-symbols--arrow-back-rounded] mr-1.5 text-lg"></span>
        <span th:text="#{common.back}">返回</span>
      </a>
    </div>

    <div
      th:if="${content != null and not #strings.isEmpty(content.html)}"
      id="content"
      class="custom-md markdown-content prose prose-base mb-5 !max-w-none dark:!prose-invert"
      th:utext="${content.html}"
    ></div>

    <div th:if="${content != null and not #lists.isEmpty(content.medium)}" class="moment-media mb-5 grid gap-3 sm:grid-cols-2">
      <div class="contents" th:each="momentItem : ${content.medium}">
        <figure th:if="${momentItem.type.name == 'PHOTO'}" class="overflow-hidden rounded-xl bg-(--btn-regular-bg)">
          <img th:src="${momentItem.url}" alt="" loading="lazy" class="h-full max-h-[28rem] w-full cursor-zoom-in object-cover" />
        </figure>
        <video
          th:if="${momentItem.type.name == 'VIDEO'}"
          th:src="${momentItem.url}"
          controls
          class="w-full rounded-xl bg-black"
        ></video>
        <audio th:if="${momentItem.type.name == 'AUDIO'}" th:src="${momentItem.url}" controls class="w-full"></audio>
        <a
          th:if="${momentItem.type.name == 'POST'}"
          th:href="${momentItem.url}"
          class="btn-regular min-h-20 rounded-xl px-4 font-bold"
        >
          <span class="icon-[material-symbols--article-outline-rounded] mr-2 text-xl"></span>
          <span class="truncate" th:text="${momentItem.url}">Post</span>
        </a>
      </div>
    </div>

    <div class="flex flex-wrap items-center justify-between gap-3 border-t border-dashed border-(--line-color) pt-4 text-sm text-50">
      <div th:if="${not #lists.isEmpty(moment.spec.tags)}" class="flex flex-wrap gap-2">
        <a
          th:each="tagName : ${moment.spec.tags}"
          th:href="@{/moments(tag=${tagName})}"
          class="link rounded-md font-medium text-(--primary)"
          th:text="${'#' + tagName}"
        >#Tag</a>
      </div>
      <div th:if="${moment.stats != null}" class="ml-auto flex gap-4">
        <span>
          <span class="icon-[material-symbols--favorite-outline-rounded] mr-1"></span>
          <span th:text="${moment.stats.upvote}">0</span>
        </span>
        <span>
          <span class="icon-[material-symbols--chat-bubble-outline-rounded] mr-1"></span>
          <span th:text="${moment.stats.approvedComment}">0</span>
        </span>
      </div>
    </div>
  </article>

  <div class="card-base relative z-10 w-full px-6 pb-4 pt-6 md:px-9" id="comment" th:if="${haloCommentEnabled}">
    <h2 class="mb-2 text-base font-medium text-gray-900 dark:text-slate-50" th:text="#{common.comment}">评论</h2>
    <Fragment set:html={'<halo:comment group="moment.halo.run" kind="Moment" th:attr="name=${moment.metadata.name}" />'} />
  </div>
</MainGridLayout>
