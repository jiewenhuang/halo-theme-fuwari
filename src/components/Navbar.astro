---
import LightDarkSwitch from "./LightDarkSwitch.svelte";
import Search from "./Search.svelte";
import DisplaySettings from "./widget/DisplaySettings.svelte";
import NavMenuPanel from "./widget/NavMenuPanel.astro";

const className = Astro.props.class;
---

<div id="navbar" class="z-50 onload-animation">
  <div class="absolute left-0 right-0 -top-8 h-8 bg-(--card-bg) transition">
  </div>
  <div
    class:list={[
      className,
      "card-base !overflow-visible mx-auto flex h-[4.5rem] max-w-(--page-width) items-center justify-between !rounded-t-none px-4",
    ]}
  >
    <a
      th:href="@{/}"
      class="btn-plain scale-animation h-[3.25rem] rounded-lg px-5 font-bold active:scale-95"
      th:aria-label="#{nav.home}"
      aria-label="Home"
    >
      <div class="flex flex-row items-center text-md text-(--primary)">
        <span class="icon-[tabler--smart-home] mb-1 mr-2 text-[1.75rem]"></span>
        <span th:text="${site.title}">Fuwari</span>
      </div>
    </a>

    <div
      class="hidden md:flex"
      th:with="menu = ${not #strings.isEmpty(theme.config.base.menu) ? menuFinder.getByName(theme.config.base.menu) : menuFinder.getPrimary()}"
    >
      <div class="contents" th:if="${menu != null}">
        <a
          th:each="menuItem : ${menu.menuItems}"
          th:href="@{${menuItem.status.href}}"
          th:target="${menuItem.spec.target?.value}"
          class="btn-plain scale-animation h-11 rounded-lg px-5 font-bold active:scale-95"
        >
          <div class="flex items-center">
            <span th:text="${menuItem.status.displayName}">Menu</span>
            <span
              th:if="${menuItem.spec.target?.value == '_blank'}"
              class="icon-[tabler--external-link] ml-1 -translate-y-px text-[1.3rem] text-black/20 transition dark:text-white/20"
            ></span>
          </div>
        </a>
      </div>
    </div>

    <div class="flex items-center">
      <Search client:only="svelte" />
      <button
        th:unless="${theme.config.base.themeColor.fixed}"
        th:aria-label="#{nav.displaySettings}"
        aria-label="Display Settings"
        class="btn-plain scale-animation h-11 w-11 rounded-lg active:scale-90"
        id="display-settings-switch"
        type="button"
      >
        <span class="icon-[material-symbols--palette-outline] text-[1.25rem]"
        ></span>
      </button>
      <LightDarkSwitch client:only="svelte" />
      <button
        th:aria-label="#{nav.menu}"
        th:name="#{nav.navMenu}"
        aria-label="Menu"
        name="Nav Menu"
        class="btn-plain scale-animation h-11 w-11 rounded-lg active:scale-90 md:!hidden"
        id="nav-menu-switch"
        type="button"
      >
        <span class="icon-[material-symbols--menu-rounded] text-[1.25rem]"
        ></span>
      </button>
    </div>

    <NavMenuPanel />
    <DisplaySettings client:only="svelte" />
  </div>
</div>

<script>
  function loadNavbarButtons() {
    const settingBtn = document.getElementById("display-settings-switch");
    settingBtn?.addEventListener("click", () => {
      document
        .getElementById("display-setting")
        ?.classList.toggle("float-panel-closed");
    });

    const menuBtn = document.getElementById("nav-menu-switch");
    menuBtn?.addEventListener("click", () => {
      document
        .getElementById("nav-menu-panel")
        ?.classList.toggle("float-panel-closed");
    });
  }

  loadNavbarButtons();
  document.addEventListener("swup:contentReplaced", loadNavbarButtons);
</script>
